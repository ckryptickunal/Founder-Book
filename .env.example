# Copy this file to `.env` and fill in your keys. NEVER commit `.env`.

# YouTube Data API v3 key — used to discover channel videos and fetch metadata.
# Get one at: https://console.cloud.google.com/  → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-data-api-key-here

# Google Gemini API key — used for ingestion (entity/topic extraction) and Q&A.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Optional model overrides (sensible defaults are used if unset) ---
# GEMINI_MODEL=gemini-3.1-flash-lite          # ingestion
# GEMINI_MODEL_QUERY=gemini-3.1-flash-lite    # interactive Q&A
# GEMINI_MODEL_LINT=gemini-2.5-flash          # wiki lint pass
